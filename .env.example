# Prisma
DATABASE_URL="postgresql://username:password@localhost:5432/pgsms?schema=public"

# Firebase client SDK
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
# Use the raw bucket name only, without gs:// or https://.
# Typical default bucket values:
# - older Firebase projects: your-project-id.appspot.com
# - newer Firebase projects: your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""
FIREBASE_MEASUREMENT_ID=""
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
# Optional public mirror of the same raw bucket name.
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Firebase admin SDK
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Auth session
SESSION_COOKIE_NAME="pgsms_session"
SESSION_ACTIVITY_COOKIE_NAME="pgsms_session_activity"
APP_BASE_URL="http://localhost:3000"

# Cron
CRON_SECRET=""

# Sentry
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"
