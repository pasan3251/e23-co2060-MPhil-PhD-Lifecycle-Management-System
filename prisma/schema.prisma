generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  SUPERVISOR
  EXAMINER
  ADMINISTRATOR
}

enum ProgramType {
  MPHIL
  PHD
  MSC
  MENG
}

enum RegistrationStatus {
  ACTIVE
  LAPSED
  ARCHIVED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  ADMITTED
  REJECTED
}

enum ProposalStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum ThesisStatus {
  SUBMITTED
  UNDER_EXAMINATION
  CORRECTIONS_REQUIRED
  FINAL_ARCHIVE
  CLOSED
}

enum VivaOutcome {
  PASS
  MINOR_CORRECTIONS
  MAJOR_CORRECTIONS
  FAIL
}

enum AcademicStatus {
  ACTIVE
  UNDER_REVIEW
  GRADUATED
  ARCHIVED
}

enum DocumentType {
  APPLICATION_ATTACHMENT
  PROPOSAL
  ETHICS_APPROVAL
  THESIS
  PROGRESS_REPORT
  CORRECTION
  REVIEW_ATTACHMENT
}

enum NotificationEvent {
  APPLICATION_STATUS_CHANGED
  PROPOSAL_STATUS_CHANGED
  ETHICS_APPROVAL_SUBMITTED
  ETHICS_APPROVAL_STATUS_CHANGED
  PROGRESS_REPORT_SUBMITTED
  PROGRESS_REPORT_SIGNED_OFF
  SUPERVISOR_SUBMISSION_AVAILABLE
  EXAMINER_REVIEW_ASSIGNED
  EXAMINER_REVIEW_SUBMITTED
  ADMIN_REVIEW_RELEASED
  THESIS_DOWNLOADED
  REGISTRATION_EXPIRY_APPROACHING
  VIVA_SCHEDULED
  CORRECTIONS_REQUIRED
  THESIS_ARCHIVED
}

enum NotificationDeliveryStatus {
  SENT
  FAILED
}

enum MaintenanceRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum CorrectionType {
  MINOR
  MAJOR
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  displayName      String
  firebaseUid      String?           @unique
  role             UserRole
  isActive         Boolean           @default(true)
  student          Student?
  supervisor       Supervisor?
  examiner         Examiner?
  administrator    Administrator?
  notifications    Notification[]
  notificationLogs NotificationLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("users")
}

model Student {
  id                    String                        @id @default(cuid())
  userId                String                        @unique
  programType           ProgramType
  academicStatus        AcademicStatus                @default(ACTIVE)
  enrollmentDate        DateTime
  updatedBy             String?
  isArchived            Boolean                       @default(false)
  user                  User                          @relation(fields: [userId], references: [id], onDelete: Restrict)
  application           Application?
  registrations         Registration[]
  researchProposals     ResearchProposal[]
  ethicsApprovals       EthicsApproval[]
  progressReports       ProgressReport[]
  theses                Thesis[]
  supervisorAssignments SupervisorAssignment[]
  examinerAssignments   ThesisExaminerAssignment[]
  reviewPanelAssignment ReviewPanelStudentAssignment?
  documents             Document[]
  notifications         Notification[]
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt

  @@index([academicStatus])
  @@map("students")
}

model Supervisor {
  id               String                 @id @default(cuid())
  userId           String                 @unique
  department       String?
  specialization   String?
  user             User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  assignments      SupervisorAssignment[]
  panelMemberships PanelMembership[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@map("supervisors")
}

model Examiner {
  id                    String                     @id @default(cuid())
  userId                String                     @unique
  department            String?
  specialization        String?
  user                  User                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  assignments           ThesisExaminerAssignment[]
  proposalEvaluations   EvaluationForm[]
  progressReportReviews ProgressReportReview[]
  panelEvaluations      PanelEvaluation[]
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  @@map("examiners")
}

model Administrator {
  id                              String                     @id @default(cuid())
  userId                          String                     @unique
  department                      String?
  user                            User                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  approvals                       CorrectionDocument[]
  supervisorAssignments           SupervisorAssignment[]     @relation("SupervisorAssignmentsAssignedBy")
  thesisExaminerAssignments       ThesisExaminerAssignment[] @relation("ThesisExaminerAssignmentsAssignedBy")
  progressReportReviewAssignments ProgressReportReview[]     @relation("ProgressReportReviewAssignedBy")
  createdAt                       DateTime                   @default(now())
  updatedAt                       DateTime                   @updatedAt

  @@map("administrators")
}

model Application {
  id                 String            @id @default(cuid())
  applicantName      String
  applicantEmail     String
  applicantPhone     String?
  supervisor         String?
  researchArea       String?
  statementOfPurpose String?
  status             ApplicationStatus @default(SUBMITTED)
  programType        ProgramType
  studentId          String?           @unique
  isArchived         Boolean           @default(false)
  student            Student?          @relation(fields: [studentId], references: [id], onDelete: SetNull)
  researchProposal   ResearchProposal?
  documents          Document[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([applicantEmail])
  @@index([status])
  @@map("applications")
}

model Registration {
  id             String             @id @default(cuid())
  studentId      String
  startDate      DateTime
  expirationDate DateTime
  status         RegistrationStatus @default(ACTIVE)
  student        Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([studentId, status])
  @@map("registrations")
}

model ResearchProposal {
  id             String           @id @default(cuid())
  studentId      String
  applicationId  String           @unique
  title          String
  abstract       String
  status         ProposalStatus   @default(SUBMITTED)
  currentVersion Int              @default(1)
  isArchived     Boolean          @default(false)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  application    Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  evaluations    EvaluationForm[]
  documents      Document[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([studentId, status])
  @@map("research_proposals")
}

model EvaluationForm {
  id                 String           @id @default(cuid())
  researchProposalId String
  examinerId         String
  feedback           String
  adminComments      String?
  releasedAt         DateTime?
  submissionDate     DateTime         @default(now())
  researchProposal   ResearchProposal @relation(fields: [researchProposalId], references: [id], onDelete: Cascade)
  examiner           Examiner         @relation(fields: [examinerId], references: [id], onDelete: Restrict)
  documents          Document[]

  @@unique([researchProposalId, examinerId])
  @@map("evaluation_forms")
}

model EthicsApproval {
  id         String     @id @default(cuid())
  studentId  String
  title      String
  summary    String
  isArchived Boolean    @default(false)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  documents  Document[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([studentId, createdAt])
  @@map("ethics_approvals")
}

model SupervisorAssignment {
  id               String        @id @default(cuid())
  studentId        String
  supervisorId     String
  supervisorUserId String
  isPrimary        Boolean       @default(false)
  assignedAt       DateTime      @default(now())
  assignedBy       String
  student          Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor       Supervisor    @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  administrator    Administrator @relation("SupervisorAssignmentsAssignedBy", fields: [assignedBy], references: [id], onDelete: Restrict)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([studentId, supervisorId])
  @@unique([studentId, supervisorUserId])
  @@index([supervisorId])
  @@index([assignedBy])
  @@map("supervisor_assignments")
}

model ProgressReport {
  id                      String                 @id @default(cuid())
  studentId               String
  periodLabel             String
  narrative               String
  isSupervisorSignedOff   Boolean                @default(false)
  supervisorSignedOffAt   DateTime?
  supervisorSignedOffById String?
  isOverdue               Boolean                @default(false)
  isArchived              Boolean                @default(false)
  student                 Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  panelEvaluations        PanelEvaluation[]
  examinerReviews         ProgressReportReview[]
  documents               Document[]
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@unique([studentId, periodLabel])
  @@index([studentId, isOverdue])
  @@map("progress_reports")
}

model ReviewPanel {
  id                 String                         @id @default(cuid())
  name               String
  description        String?
  cohortProgramType  ProgramType?
  memberships        PanelMembership[]
  studentAssignments ReviewPanelStudentAssignment[]
  evaluations        PanelEvaluation[]
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt

  @@map("review_panels")
}

model PanelMembership {
  id            String      @id @default(cuid())
  reviewPanelId String
  supervisorId  String
  reviewPanel   ReviewPanel @relation(fields: [reviewPanelId], references: [id], onDelete: Cascade)
  supervisor    Supervisor  @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([reviewPanelId, supervisorId])
  @@map("panel_memberships")
}

model PanelEvaluation {
  id               String         @id @default(cuid())
  reviewPanelId    String
  progressReportId String
  examinerId       String
  notes            String?
  submittedAt      DateTime?
  reviewPanel      ReviewPanel    @relation(fields: [reviewPanelId], references: [id], onDelete: Cascade)
  progressReport   ProgressReport @relation(fields: [progressReportId], references: [id], onDelete: Cascade)
  examiner         Examiner       @relation(fields: [examinerId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([reviewPanelId, progressReportId, examinerId])
  @@index([progressReportId, examinerId])
  @@map("panel_evaluations")
}

model ProgressReportReview {
  id               String         @id @default(cuid())
  progressReportId String
  examinerId       String
  examinerUserId   String
  assignedAt       DateTime       @default(now())
  assignedBy       String
  reviewText       String?
  submittedAt      DateTime?
  adminComments    String?
  releasedAt       DateTime?
  progressReport   ProgressReport @relation(fields: [progressReportId], references: [id], onDelete: Cascade)
  examiner         Examiner       @relation(fields: [examinerId], references: [id], onDelete: Cascade)
  administrator    Administrator  @relation("ProgressReportReviewAssignedBy", fields: [assignedBy], references: [id], onDelete: Restrict)
  documents        Document[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([progressReportId, examinerId])
  @@unique([progressReportId, examinerUserId])
  @@index([examinerId])
  @@index([assignedBy])
  @@map("progress_report_reviews")
}

model ReviewPanelStudentAssignment {
  id            String      @id @default(cuid())
  reviewPanelId String
  studentId     String      @unique
  reviewPanel   ReviewPanel @relation(fields: [reviewPanelId], references: [id], onDelete: Cascade)
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([reviewPanelId, studentId])
  @@index([reviewPanelId])
  @@map("review_panel_student_assignments")
}

model Thesis {
  id                  String                     @id @default(cuid())
  studentId           String
  title               String
  abstract            String
  status              ThesisStatus               @default(SUBMITTED)
  isArchived          Boolean                    @default(false)
  student             Student                    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examinerAssignments ThesisExaminerAssignment[]
  viva                Viva?
  corrections         CorrectionDocument[]
  documents           Document[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([studentId, status])
  @@map("theses")
}

model ThesisExaminerAssignment {
  id             String        @id @default(cuid())
  thesisId       String
  studentId      String
  examinerId     String
  examinerUserId String
  assignedAt     DateTime      @default(now())
  assignedBy     String
  reviewText     String?
  submittedAt    DateTime?
  adminComments  String?
  releasedAt     DateTime?
  thesis         Thesis        @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examiner       Examiner      @relation(fields: [examinerId], references: [id], onDelete: Cascade)
  administrator  Administrator @relation("ThesisExaminerAssignmentsAssignedBy", fields: [assignedBy], references: [id], onDelete: Restrict)
  documents      Document[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([thesisId, examinerId])
  @@unique([studentId, examinerUserId])
  @@index([studentId, examinerId])
  @@index([assignedBy])
  @@map("thesis_examiner_assignments")
}

model Viva {
  id            String       @id @default(cuid())
  thesisId      String       @unique
  scheduledDate DateTime
  venue         String
  outcome       VivaOutcome?
  thesis        Thesis       @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("vivas")
}

model CorrectionDocument {
  id             String         @id @default(cuid())
  thesisId       String
  correctionType CorrectionType
  description    String?
  isApproved     Boolean        @default(false)
  approvedAt     DateTime?
  approvedById   String?
  thesis         Thesis         @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  approvedBy     Administrator? @relation(fields: [approvedById], references: [id], onDelete: SetNull)
  documents      Document[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([thesisId, isApproved])
  @@map("correction_documents")
}

model Document {
  id                         String                    @id @default(cuid())
  documentType               DocumentType
  fileName                   String
  storagePath                String
  mimeType                   String
  version                    Int                       @default(1)
  isCurrentVersion           Boolean                   @default(true)
  isDeleted                  Boolean                   @default(false)
  applicationId              String?
  studentId                  String?
  researchProposalId         String?
  ethicsApprovalId           String?
  progressReportId           String?
  progressReportReviewId     String?
  thesisId                   String?
  thesisExaminerAssignmentId String?
  correctionDocumentId       String?
  evaluationFormId           String?
  application                Application?              @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  student                    Student?                  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  researchProposal           ResearchProposal?         @relation(fields: [researchProposalId], references: [id], onDelete: SetNull)
  ethicsApproval             EthicsApproval?           @relation(fields: [ethicsApprovalId], references: [id], onDelete: SetNull)
  progressReport             ProgressReport?           @relation(fields: [progressReportId], references: [id], onDelete: SetNull)
  progressReportReview       ProgressReportReview?     @relation(fields: [progressReportReviewId], references: [id], onDelete: SetNull)
  thesis                     Thesis?                   @relation(fields: [thesisId], references: [id], onDelete: SetNull)
  thesisExaminerAssignment   ThesisExaminerAssignment? @relation(fields: [thesisExaminerAssignmentId], references: [id], onDelete: SetNull)
  correctionDocument         CorrectionDocument?       @relation(fields: [correctionDocumentId], references: [id], onDelete: SetNull)
  evaluationForm             EvaluationForm?           @relation(fields: [evaluationFormId], references: [id], onDelete: SetNull)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  @@index([documentType, isDeleted])
  @@index([researchProposalId, version])
  @@index([ethicsApprovalId])
  @@index([progressReportReviewId])
  @@index([thesisId, version])
  @@index([thesisExaminerAssignmentId])
  @@index([evaluationFormId])
  @@map("documents")
}

model Notification {
  id          String            @id @default(cuid())
  recipientId String
  studentId   String?
  event       NotificationEvent
  title       String
  message     String
  isRead      Boolean           @default(false)
  recipient   User              @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  student     Student?          @relation(fields: [studentId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([recipientId, isRead])
  @@map("notifications")
}

model NotificationLog {
  id             String                     @id @default(cuid())
  recipientId    String
  event          NotificationEvent
  subject        String
  deliveryStatus NotificationDeliveryStatus
  failureReason  String?
  metadata       Json?
  recipient      User                       @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([recipientId, deliveryStatus])
  @@index([event, createdAt])
  @@map("notification_logs")
}

model MaintenanceRun {
  id           String               @id @default(cuid())
  jobName      String
  runKey       String
  status       MaintenanceRunStatus @default(RUNNING)
  result       Json?
  errorMessage String?
  startedAt    DateTime             @default(now())
  completedAt  DateTime?
  failedAt     DateTime?
  updatedAt    DateTime             @updatedAt

  @@unique([jobName, runKey])
  @@index([status, startedAt])
  @@map("maintenance_runs")
}
