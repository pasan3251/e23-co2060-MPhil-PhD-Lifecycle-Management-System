generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  displayName      String
  firebaseUid      String?           @unique
  role             UserRole
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  administrator    Administrator?
  examiner         Examiner?
  notificationLogs NotificationLog[]
  notifications    Notification[]
  student          Student?
  supervisor       Supervisor?

  @@map("users")
}

model Student {
  id                    String                     @id @default(cuid())
  userId                String                     @unique
  programType           ProgramType
  academicStatus        AcademicStatus             @default(ACTIVE)
  enrollmentDate        DateTime
  updatedBy             String?
  isArchived            Boolean                    @default(false)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  application           Application?
  documents             Document[]
  notifications         Notification[]
  progressReports       ProgressReport[]
  registrations         Registration[]
  researchProposals     ResearchProposal[]
  user                  User                       @relation(fields: [userId], references: [id])
  supervisorAssignments SupervisorAssignment[]
  theses                Thesis[]
  examinerAssignments   ThesisExaminerAssignment[]

  @@index([academicStatus])
  @@map("students")
}

model Supervisor {
  id               String                 @id @default(cuid())
  userId           String                 @unique
  department       String?
  specialization   String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  evaluations      EvaluationForm[]
  panelMemberships PanelMembership[]
  assignments      SupervisorAssignment[]
  user             User                   @relation(fields: [userId], references: [id])

  @@map("supervisors")
}

model Examiner {
  id             String                     @id @default(cuid())
  userId         String                     @unique
  department     String?
  specialization String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  user           User                       @relation(fields: [userId], references: [id])
  assignments    ThesisExaminerAssignment[]

  @@map("examiners")
}

model Administrator {
  id         String               @id @default(cuid())
  userId     String               @unique
  department String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  user       User                 @relation(fields: [userId], references: [id])
  approvals  CorrectionDocument[]

  @@map("administrators")
}

model Application {
  id                 String            @id @default(cuid())
  applicantName      String
  applicantEmail     String
  applicantPhone     String?
  researchArea       String?
  statementOfPurpose String?
  status             ApplicationStatus @default(SUBMITTED)
  programType        ProgramType
  studentId          String?           @unique
  isArchived         Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  student            Student?          @relation(fields: [studentId], references: [id])
  documents          Document[]
  researchProposal   ResearchProposal?

  @@index([applicantEmail])
  @@index([status])
  @@map("applications")
}

model Registration {
  id             String             @id @default(cuid())
  studentId      String
  startDate      DateTime
  expirationDate DateTime
  status         RegistrationStatus @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  student        Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@map("registrations")
}

model ResearchProposal {
  id             String           @id @default(cuid())
  studentId      String
  applicationId  String           @unique
  title          String
  abstract       String
  status         ProposalStatus   @default(SUBMITTED)
  currentVersion Int              @default(1)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  documents      Document[]
  evaluations    EvaluationForm[]
  application    Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@map("research_proposals")
}

model EvaluationForm {
  id                 String           @id @default(cuid())
  researchProposalId String
  supervisorId       String
  score              Int
  feedback           String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  researchProposal   ResearchProposal @relation(fields: [researchProposalId], references: [id], onDelete: Cascade)
  supervisor         Supervisor       @relation(fields: [supervisorId], references: [id])

  @@unique([researchProposalId, supervisorId])
  @@map("evaluation_forms")
}

model SupervisorAssignment {
  id               String     @id @default(cuid())
  studentId        String
  supervisorId     String
  supervisorUserId String
  isPrimary        Boolean    @default(false)
  assignedAt       DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  student          Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor       Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)

  @@unique([studentId, supervisorId])
  @@unique([studentId, supervisorUserId])
  @@index([supervisorId])
  @@map("supervisor_assignments")
}

model ProgressReport {
  id                    String            @id @default(cuid())
  studentId             String
  periodLabel           String
  narrative             String
  isSupervisorSignedOff Boolean           @default(false)
  supervisorSignedOffAt DateTime?
  isOverdue             Boolean           @default(false)
  isArchived            Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  documents             Document[]
  panelEvaluations      PanelEvaluation[]
  student               Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, periodLabel])
  @@index([studentId, isOverdue])
  @@map("progress_reports")
}

model ReviewPanel {
  id          String            @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  evaluations PanelEvaluation[]
  memberships PanelMembership[]

  @@map("review_panels")
}

model PanelMembership {
  id            String      @id @default(cuid())
  reviewPanelId String
  supervisorId  String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  reviewPanel   ReviewPanel @relation(fields: [reviewPanelId], references: [id], onDelete: Cascade)
  supervisor    Supervisor  @relation(fields: [supervisorId], references: [id], onDelete: Cascade)

  @@unique([reviewPanelId, supervisorId])
  @@map("panel_memberships")
}

model PanelEvaluation {
  id               String         @id @default(cuid())
  reviewPanelId    String
  progressReportId String
  score            Int?
  feedback         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  progressReport   ProgressReport @relation(fields: [progressReportId], references: [id], onDelete: Cascade)
  reviewPanel      ReviewPanel    @relation(fields: [reviewPanelId], references: [id], onDelete: Cascade)

  @@unique([reviewPanelId, progressReportId])
  @@map("panel_evaluations")
}

model Thesis {
  id                  String                     @id @default(cuid())
  studentId           String
  title               String
  abstract            String
  status              ThesisStatus               @default(SUBMITTED)
  isArchived          Boolean                    @default(false)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  corrections         CorrectionDocument[]
  documents           Document[]
  student             Student                    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examinerAssignments ThesisExaminerAssignment[]
  viva                Viva?

  @@index([studentId, status])
  @@map("theses")
}

model ThesisExaminerAssignment {
  id             String   @id @default(cuid())
  thesisId       String
  studentId      String
  examinerId     String
  examinerUserId String
  assignedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  examiner       Examiner @relation(fields: [examinerId], references: [id], onDelete: Cascade)
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  thesis         Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@unique([thesisId, examinerId])
  @@unique([studentId, examinerUserId])
  @@index([studentId, examinerId])
  @@map("thesis_examiner_assignments")
}

model Viva {
  id            String       @id @default(cuid())
  thesisId      String       @unique
  scheduledDate DateTime
  venue         String
  outcome       VivaOutcome?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  thesis        Thesis       @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@map("vivas")
}

model CorrectionDocument {
  id             String         @id @default(cuid())
  thesisId       String
  correctionType CorrectionType
  description    String?
  isApproved     Boolean        @default(false)
  approvedAt     DateTime?
  approvedById   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  approvedBy     Administrator? @relation(fields: [approvedById], references: [id])
  thesis         Thesis         @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  documents      Document[]

  @@index([thesisId, isApproved])
  @@map("correction_documents")
}

model Document {
  id                   String              @id @default(cuid())
  documentType         DocumentType
  fileName             String
  storagePath          String
  mimeType             String
  version              Int                 @default(1)
  isCurrentVersion     Boolean             @default(true)
  isDeleted            Boolean             @default(false)
  applicationId        String?
  studentId            String?
  researchProposalId   String?
  progressReportId     String?
  thesisId             String?
  correctionDocumentId String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  application          Application?        @relation(fields: [applicationId], references: [id])
  correctionDocument   CorrectionDocument? @relation(fields: [correctionDocumentId], references: [id])
  progressReport       ProgressReport?     @relation(fields: [progressReportId], references: [id])
  researchProposal     ResearchProposal?   @relation(fields: [researchProposalId], references: [id])
  student              Student?            @relation(fields: [studentId], references: [id])
  thesis               Thesis?             @relation(fields: [thesisId], references: [id])

  @@index([documentType, isDeleted])
  @@index([researchProposalId, version])
  @@index([thesisId, version])
  @@map("documents")
}

model Notification {
  id          String            @id @default(cuid())
  recipientId String
  studentId   String?
  event       NotificationEvent
  title       String
  message     String
  isRead      Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  recipient   User              @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  student     Student?          @relation(fields: [studentId], references: [id])

  @@index([recipientId, isRead])
  @@map("notifications")
}

model NotificationLog {
  id             String                     @id @default(cuid())
  recipientId    String
  event          NotificationEvent
  subject        String
  deliveryStatus NotificationDeliveryStatus
  failureReason  String?
  metadata       Json?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  recipient      User                       @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, deliveryStatus])
  @@index([event, createdAt])
  @@map("notification_logs")
}

enum UserRole {
  STUDENT
  SUPERVISOR
  EXAMINER
  ADMINISTRATOR
}

enum ProgramType {
  MPHIL
  PHD
  MSC
  MENG
}

enum RegistrationStatus {
  ACTIVE
  LAPSED
  ARCHIVED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  ADMITTED
  REJECTED
}

enum ProposalStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum ThesisStatus {
  SUBMITTED
  UNDER_EXAMINATION
  CORRECTIONS_REQUIRED
  FINAL_ARCHIVE
  CLOSED
}

enum VivaOutcome {
  PASS
  MINOR_CORRECTIONS
  MAJOR_CORRECTIONS
  FAIL
}

enum AcademicStatus {
  ACTIVE
  UNDER_REVIEW
  GRADUATED
  ARCHIVED
}

enum DocumentType {
  APPLICATION_ATTACHMENT
  PROPOSAL
  THESIS
  PROGRESS_REPORT
  CORRECTION
}

enum NotificationEvent {
  APPLICATION_STATUS_CHANGED
  PROPOSAL_STATUS_CHANGED
  PROGRESS_REPORT_SUBMITTED
  REGISTRATION_EXPIRY_APPROACHING
  VIVA_SCHEDULED
  CORRECTIONS_REQUIRED
  THESIS_ARCHIVED
}

enum NotificationDeliveryStatus {
  SENT
  FAILED
}

enum CorrectionType {
  MINOR
  MAJOR
}
